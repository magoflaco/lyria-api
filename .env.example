# Copy to .env and adjust as needed. All values are optional (sane defaults applied).

# HTTP server port
PORT=8787

# Optional bearer token to protect this wrapper's own HTTP endpoints.
# If set, callers must send: Authorization: Bearer <API_KEY>
API_KEY=

# Where generated audio is written
DOWNLOAD_DIR=./downloads

# Path to the Flow Music session file produced during login extraction
SESSION_FILE=./secrets/session.json

# Default audio format for downloads: wav | m4a
DEFAULT_FORMAT=wav

# Max seconds to wait for a clip to finish rendering before timing out
CLIP_TIMEOUT_SECONDS=240
